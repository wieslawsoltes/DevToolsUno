<UserControl
    x:Class="DevTools.Uno.Diagnostics.Views.ControlDetailsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:automation="using:Microsoft.UI.Xaml.Automation"
    xmlns:controls="using:Avalonia.Controls"
    xmlns:views="using:DevTools.Uno.Diagnostics.Views"
    automation:AutomationProperties.Name="Control details">
    <Grid x:Name="LayoutRoot"
          MinHeight="0"
          MinWidth="0"
          Padding="{ThemeResource DevToolsPagePadding}"
          RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
                <TextBlock Style="{StaticResource DevToolsPageTitleTextStyle}"
                           Text="{Binding SelectedElementName}" />
                <TextBlock Style="{StaticResource DevToolsMetaTextStyle}"
                           Text="{Binding SelectedElementType}" />
            </StackPanel>
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Center">
                <Button x:Name="ToggleDetailsButton"
                        Content="Hide Details"
                        automation:AutomationProperties.Name="Show or hide details panel" />
                <Button Command="{Binding TogglePinCommand}"
                        Content="Pin Selected"
                        automation:AutomationProperties.Name="Pin or unpin selected property" />
                <Button Command="{Binding CopyValueCommand}"
                        Content="Copy Value"
                        automation:AutomationProperties.Name="Copy selected property value" />
            </StackPanel>
        </Grid>

        <TextBox Grid.Row="1"
                 PlaceholderText="Filter properties"
                 Text="{Binding Filter.FilterString, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 automation:AutomationProperties.Name="Filter properties" />

        <Grid Grid.Row="2"
              MinHeight="0"
              MinWidth="0"
              ColumnSpacing="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="PropertyColumn"
                                  Width="2*"
                                  MinWidth="360" />
                <ColumnDefinition x:Name="DetailsSplitterColumn"
                                  Width="8" />
                <ColumnDefinition x:Name="DetailsColumn"
                                  Width="*"
                                  MinWidth="260" />
            </Grid.ColumnDefinitions>

            <Border Margin="0,0,12,0"
                    MinHeight="0"
                    MinWidth="0"
                    Style="{StaticResource DevToolsDataPanelBorderStyle}">
                <controls:TreeDataGrid x:Name="PropertyGrid"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Stretch"
                                       Source="{Binding PropertySource}"
                                       automation:AutomationProperties.Name="Property grid" />
            </Border>

            <Border x:Name="DetailsSplitter"
                    Grid.Column="1"
                    Width="8"
                    Background="Transparent"
                    automation:AutomationProperties.Name="Resize properties and details panes" />

            <ScrollViewer x:Name="DetailsPanel"
                          Grid.Column="2"
                          Margin="12,0,0,0"
                          MinHeight="0"
                          MinWidth="0"
                          automation:AutomationProperties.Name="Property metadata">
                <StackPanel Spacing="12">
                    <Border Style="{StaticResource DevToolsInspectorCardBorderStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock Style="{StaticResource DevToolsSectionTitleTextStyle}" Text="Selected Property" />
                            <ContentControl Content="{Binding SelectedProperty}"
                                            ContentTemplate="{StaticResource SelectedPropertyEditorTemplate}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource DevToolsInspectorCardBorderStyle}">
                        <StackPanel Spacing="4">
                            <TextBlock Style="{StaticResource DevToolsSectionTitleTextStyle}" Text="Element" />
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Foreground="{ThemeResource DevToolsForegroundCaptionBrush}" Text="State:" />
                                <TextBlock Foreground="{ThemeResource DevToolsForegroundMutedBrush}" Text="{Binding Metadata.State}" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Foreground="{ThemeResource DevToolsForegroundCaptionBrush}" Text="Selector:" />
                                <TextBlock Foreground="{ThemeResource DevToolsForegroundMutedBrush}" Text="{Binding Metadata.Selector}" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Foreground="{ThemeResource DevToolsForegroundCaptionBrush}" Text="DataContext:" />
                                <TextBlock Foreground="{ThemeResource DevToolsForegroundMutedBrush}" Text="{Binding Metadata.DataContext}" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Foreground="{ThemeResource DevToolsForegroundCaptionBrush}" Text="Automation:" />
                                <TextBlock Foreground="{ThemeResource DevToolsForegroundMutedBrush}" Text="{Binding Metadata.AutomationName}" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Foreground="{ThemeResource DevToolsForegroundCaptionBrush}" Text="AutomationId:" />
                                <TextBlock Foreground="{ThemeResource DevToolsForegroundMutedBrush}" Text="{Binding Metadata.AutomationId}" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Foreground="{ThemeResource DevToolsForegroundCaptionBrush}" Text="ToolTip:" />
                                <TextBlock Foreground="{ThemeResource DevToolsForegroundMutedBrush}" Text="{Binding Metadata.ToolTip}" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Foreground="{ThemeResource DevToolsForegroundCaptionBrush}" Text="Popup Surfaces:" />
                                <TextBlock Foreground="{ThemeResource DevToolsForegroundMutedBrush}" Text="{Binding Metadata.PopupSurfaces}" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Foreground="{ThemeResource DevToolsForegroundCaptionBrush}" Text="Interaction:" />
                                <TextBlock Foreground="{ThemeResource DevToolsForegroundMutedBrush}" Text="{Binding Metadata.Interaction}" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Foreground="{ThemeResource DevToolsForegroundCaptionBrush}" Text="XamlRoot:" />
                                <TextBlock Foreground="{ThemeResource DevToolsForegroundMutedBrush}" Text="{Binding Metadata.XamlRoot}" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Foreground="{ThemeResource DevToolsForegroundCaptionBrush}" Text="Popup:" />
                                <TextBlock Foreground="{ThemeResource DevToolsForegroundMutedBrush}" Text="{Binding Metadata.PopupState}" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource DevToolsInspectorCardBorderStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock Style="{StaticResource DevToolsSectionTitleTextStyle}" Text="Layout" />
                            <views:LayoutExplorerView DataContext="{Binding Layout}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource DevToolsInspectorCardBorderStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock Style="{StaticResource DevToolsSectionTitleTextStyle}" Text="Value Sources" />
                            <controls:TreeDataGrid Source="{Binding ValueSourceGrid}"
                                                   HorizontalAlignment="Stretch"
                                                   VerticalAlignment="Stretch"
                                                   automation:AutomationProperties.Name="Value sources" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
