<UserControl
    x:Class="DevToolsUno.Diagnostics.Views.StylesPageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:automation="using:Microsoft.UI.Xaml.Automation"
    xmlns:controls="using:Uno.Controls"
    xmlns:views="using:DevToolsUno.Diagnostics.Views"
    automation:AutomationProperties.Name="Styles inspection page">
    <Grid x:Name="LayoutRoot"
          MinHeight="0"
          MinWidth="0"
          ColumnSpacing="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="ScopeColumn"
                              Width="1.2*"
                              MinWidth="240" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition x:Name="ContentColumn"
                              Width="1.8*"
                              MinWidth="420" />
        </Grid.ColumnDefinitions>

        <Grid MinHeight="0"
              MinWidth="0"
              Margin="0,0,8,0"
              RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="8">
                <StackPanel Spacing="4">
                    <TextBlock Style="{StaticResource DevToolsPageTitleTextStyle}"
                               Text="Scopes" />
                    <TextBlock Style="{StaticResource DevToolsBodyTextStyle}"
                               Text="{Binding InspectionTargetSummary}"
                               TextWrapping="WrapWholeWords" />
                </StackPanel>
                <views:WrapPanel HorizontalSpacing="8"
                                 VerticalSpacing="8">
                    <Button Command="{Binding RefreshCommand}"
                            Content="Refresh"
                            automation:AutomationProperties.Name="Refresh styles" />
                    <Button Command="{Binding ExpandAllCommand}"
                            Content="Expand"
                            automation:AutomationProperties.Name="Expand all style scopes" />
                    <Button Command="{Binding CollapseAllCommand}"
                            Content="Collapse"
                            automation:AutomationProperties.Name="Collapse all style scopes" />
                </views:WrapPanel>
            </StackPanel>

            <Border Grid.Row="1"
                    MinHeight="0"
                    MinWidth="0"
                    Style="{StaticResource DevToolsDataPanelBorderStyle}">
                <controls:TreeDataGrid x:Name="ScopeTree"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Stretch"
                                       Source="{Binding ScopeTreeSource}"
                                       automation:AutomationProperties.Name="Style scopes" />
            </Border>
        </Grid>

        <Border x:Name="PaneSplitter"
                Grid.Column="1"
                Width="8"
                Background="Transparent"
                automation:AutomationProperties.Name="Resize scopes and styles panes" />

        <Grid Grid.Column="2"
              Margin="8,0,0,0"
              MinHeight="0"
              MinWidth="0"
              RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="8">
                <StackPanel Spacing="4">
                    <TextBlock Style="{StaticResource DevToolsPageTitleTextStyle}"
                               Text="{Binding SelectedScopeName}" />
                    <TextBlock Style="{StaticResource DevToolsBodyTextStyle}"
                               Text="{Binding SelectedScopeSummary}"
                               TextWrapping="WrapWholeWords" />
                    <TextBlock Style="{StaticResource DevToolsMetaTextStyle}"
                               Text="{Binding SelectedScopePath}"
                               TextWrapping="WrapWholeWords" />
                </StackPanel>
                <views:WrapPanel HorizontalSpacing="8"
                                 VerticalSpacing="8">
                    <Button Command="{Binding CopySelectedNameCommand}"
                            Content="Copy Name"
                            automation:AutomationProperties.Name="Copy selected style entry name" />
                    <Button Command="{Binding CopySelectedValueCommand}"
                            Content="Copy Value"
                            automation:AutomationProperties.Name="Copy selected style entry value" />
                </views:WrapPanel>
            </StackPanel>

            <Grid Grid.Row="1"
                  ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox PlaceholderText="Filter style entries by name, value, type, or origin"
                         Text="{Binding Filter.FilterString, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         automation:AutomationProperties.Name="Filter styles" />
                <ComboBox Grid.Column="1"
                          Width="120"
                          ItemsSource="{Binding SortOptions}"
                          SelectedItem="{Binding SelectedSortOption, Mode=TwoWay}"
                          automation:AutomationProperties.Name="Sort styles by" />
                <ToggleButton Grid.Column="2"
                              IsChecked="{Binding SortDescending, Mode=TwoWay}"
                              Content="Descending"
                              automation:AutomationProperties.Name="Toggle descending style sort" />
            </Grid>

            <TabView x:Name="ContentTabs"
                     Grid.Row="2"
                     MinHeight="0"
                     MinWidth="0"
                     Style="{StaticResource DevToolsEmbeddedTabViewStyle}">
                <TabViewItem Header="Entries">
                    <Grid MinHeight="0"
                          MinWidth="0"
                          Padding="0,8,0,0"
                          RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Foreground="{ThemeResource DevToolsForegroundCaptionBrush}"
                                   Text="{Binding EntryCountText}" />

                        <Border Grid.Row="1"
                                MinHeight="0"
                                MinWidth="0"
                                Style="{StaticResource DevToolsDataPanelBorderStyle}">
                            <controls:TreeDataGrid x:Name="EntriesGrid"
                                                   HorizontalAlignment="Stretch"
                                                   VerticalAlignment="Stretch"
                                                   Source="{Binding EntrySource}"
                                                   automation:AutomationProperties.Name="Style entries grid" />
                        </Border>
                    </Grid>
                </TabViewItem>
                <TabViewItem Header="Inspector">
                    <Border MinHeight="0"
                            MinWidth="0"
                            Padding="0,8,0,0"
                            Background="Transparent">
                        <views:StyleValueDetailsView x:Name="DetailsView"
                                                     HorizontalAlignment="Stretch"
                                                     VerticalAlignment="Stretch"
                                                     DataContext="{Binding Details}" />
                    </Border>
                </TabViewItem>
            </TabView>
        </Grid>
    </Grid>
</UserControl>
