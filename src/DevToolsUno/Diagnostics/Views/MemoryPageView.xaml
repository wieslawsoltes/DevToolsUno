<UserControl
    x:Class="DevToolsUno.Diagnostics.Views.MemoryPageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:automation="using:Microsoft.UI.Xaml.Automation"
    xmlns:controls="using:Avalonia.Controls"
    xmlns:views="using:DevToolsUno.Diagnostics.Views"
    automation:AutomationProperties.Name="Memory diagnostics page">
    <Grid x:Name="LayoutRoot"
          MinHeight="0"
          MinWidth="0"
          ColumnSpacing="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.15*" />
            <ColumnDefinition Width="1.85*" />
        </Grid.ColumnDefinitions>

        <Grid MinHeight="0"
              MinWidth="0"
              RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="8">
                <StackPanel Spacing="4">
                    <TextBlock Style="{StaticResource DevToolsPageTitleTextStyle}"
                               Text="Memory" />
                    <TextBlock Style="{StaticResource DevToolsBodyTextStyle}"
                               Text="{Binding InspectionTargetSummary}"
                               TextWrapping="WrapWholeWords" />
                    <TextBlock Style="{StaticResource DevToolsMetaTextStyle}"
                               Text="{Binding StatusText}"
                               TextWrapping="WrapWholeWords" />
                </StackPanel>
                <views:WrapPanel HorizontalSpacing="8"
                                 VerticalSpacing="8">
                    <Button Command="{Binding RefreshCommand}"
                            Content="Refresh"
                            automation:AutomationProperties.Name="Refresh memory diagnostics" />
                    <Button Command="{Binding ToggleSamplingCommand}"
                            Content="{Binding SamplingButtonText}"
                            automation:AutomationProperties.Name="Toggle live memory sampling" />
                    <Button Command="{Binding ForceGcCommand}"
                            Content="Force GC"
                            automation:AutomationProperties.Name="Force garbage collection" />
                    <Button Command="{Binding ResetHistoryCommand}"
                            Content="Reset History"
                            automation:AutomationProperties.Name="Reset memory sample history" />
                </views:WrapPanel>
            </StackPanel>

            <Border Grid.Row="1"
                    Style="{StaticResource DevToolsInspectorCardBorderStyle}">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="6">
                        <TextBlock Style="{StaticResource DevToolsSectionTitleTextStyle}"
                                   Text="Current Sample" />
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Foreground="{ThemeResource DevToolsForegroundCaptionBrush}" Text="Managed Heap:" />
                            <TextBlock Foreground="{ThemeResource DevToolsForegroundMutedBrush}" Text="{Binding CurrentManagedHeapText}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Foreground="{ThemeResource DevToolsForegroundCaptionBrush}" Text="Heap Δ:" />
                            <TextBlock Foreground="{ThemeResource DevToolsForegroundMutedBrush}" Text="{Binding CurrentHeapDeltaText}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Foreground="{ThemeResource DevToolsForegroundCaptionBrush}" Text="Allocated:" />
                            <TextBlock Foreground="{ThemeResource DevToolsForegroundMutedBrush}" Text="{Binding CurrentAllocatedText}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Foreground="{ThemeResource DevToolsForegroundCaptionBrush}" Text="Allocated Δ:" />
                            <TextBlock Foreground="{ThemeResource DevToolsForegroundMutedBrush}" Text="{Binding CurrentAllocatedDeltaText}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Foreground="{ThemeResource DevToolsForegroundCaptionBrush}" Text="GC:" />
                            <TextBlock Foreground="{ThemeResource DevToolsForegroundMutedBrush}" Text="{Binding CurrentGcCollectionsText}" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="6">
                        <TextBlock Style="{StaticResource DevToolsSectionTitleTextStyle}"
                                   Text="Process And Tree" />
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Foreground="{ThemeResource DevToolsForegroundCaptionBrush}" Text="Working Set:" />
                            <TextBlock Foreground="{ThemeResource DevToolsForegroundMutedBrush}" Text="{Binding CurrentWorkingSetText}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Foreground="{ThemeResource DevToolsForegroundCaptionBrush}" Text="Private Memory:" />
                            <TextBlock Foreground="{ThemeResource DevToolsForegroundMutedBrush}" Text="{Binding CurrentPrivateMemoryText}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Foreground="{ThemeResource DevToolsForegroundCaptionBrush}" Text="Process:" />
                            <TextBlock Foreground="{ThemeResource DevToolsForegroundMutedBrush}" Text="{Binding CurrentProcessText}" TextWrapping="WrapWholeWords" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Foreground="{ThemeResource DevToolsForegroundCaptionBrush}" Text="Selection:" />
                            <TextBlock Foreground="{ThemeResource DevToolsForegroundMutedBrush}" Text="{Binding CurrentSelectionText}" TextWrapping="WrapWholeWords" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Foreground="{ThemeResource DevToolsForegroundCaptionBrush}" Text="Selection Tree:" />
                            <TextBlock Foreground="{ThemeResource DevToolsForegroundMutedBrush}" Text="{Binding CurrentSelectionCountsText}" TextWrapping="WrapWholeWords" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Foreground="{ThemeResource DevToolsForegroundCaptionBrush}" Text="Host Root Tree:" />
                            <TextBlock Foreground="{ThemeResource DevToolsForegroundMutedBrush}" Text="{Binding CurrentRootCountsText}" TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <TextBlock Grid.Row="2"
                       Foreground="{ThemeResource DevToolsForegroundCaptionBrush}"
                       Text="{Binding SampleCountText}" />

            <Border Grid.Row="3"
                    MinHeight="0"
                    MinWidth="0"
                    Style="{StaticResource DevToolsDataPanelBorderStyle}">
                <controls:TreeDataGrid x:Name="SamplesGrid"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Stretch"
                                       Source="{Binding SampleSource}"
                                       automation:AutomationProperties.Name="Memory samples grid" />
            </Border>
        </Grid>

        <Grid Grid.Column="1"
              MinHeight="0"
              MinWidth="0"
              RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="4">
                <TextBlock Style="{StaticResource DevToolsPageTitleTextStyle}"
                           Text="{Binding SelectedSampleName}" />
                <TextBlock Style="{StaticResource DevToolsBodyTextStyle}"
                           Text="{Binding SelectedSampleSummary}"
                           TextWrapping="WrapWholeWords" />
                <TextBlock Style="{StaticResource DevToolsMetaTextStyle}"
                           Text="{Binding CurrentSnapshotSummary}"
                           TextWrapping="WrapWholeWords" />
            </StackPanel>

            <TabView x:Name="ContentTabs"
                     Grid.Row="1"
                     MinHeight="0"
                     MinWidth="0"
                     Style="{StaticResource DevToolsEmbeddedTabViewStyle}">
                <TabViewItem Header="Snapshot">
                    <Grid MinHeight="0"
                          MinWidth="0"
                          Padding="0,8,0,0">
                        <Border MinHeight="0"
                                MinWidth="0"
                                Style="{StaticResource DevToolsDataPanelBorderStyle}">
                            <ListView x:Name="DetailList"
                                      ItemsSource="{Binding DetailItems}"
                                      SelectedItem="{Binding SelectedDetailItem, Mode=TwoWay}"
                                      Style="{StaticResource DevToolsFlatListViewStyle}"
                                      automation:AutomationProperties.Name="Memory snapshot objects">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,8" ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock FontWeight="SemiBold"
                                                       Foreground="{ThemeResource DevToolsForegroundBrush}"
                                                       Text="{Binding Name}" />
                                            <StackPanel Grid.Column="1"
                                                        Spacing="2">
                                                <TextBlock Foreground="{ThemeResource DevToolsForegroundMutedBrush}"
                                                           Text="{Binding Value}"
                                                           TextWrapping="WrapWholeWords" />
                                                <TextBlock FontSize="12"
                                                           Foreground="{ThemeResource DevToolsForegroundSubtleBrush}"
                                                           Text="{Binding Detail}"
                                                           TextWrapping="WrapWholeWords" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Border>
                    </Grid>
                </TabViewItem>
                <TabViewItem Header="Tracked Objects">
                    <Grid MinHeight="0"
                          MinWidth="0"
                          Padding="0,8,0,0"
                          RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Spacing="8">
                            <StackPanel Spacing="4">
                                <TextBlock Style="{StaticResource DevToolsPageTitleTextStyle}"
                                           Text="Tracked Objects" />
                                <TextBlock Style="{StaticResource DevToolsBodyTextStyle}"
                                           Text="{Binding TrackedSelectionSummary}"
                                           TextWrapping="WrapWholeWords" />
                                <TextBlock Foreground="{ThemeResource DevToolsForegroundCaptionBrush}"
                                           Text="{Binding TrackedCountText}" />
                            </StackPanel>
                            <views:WrapPanel HorizontalSpacing="8"
                                             VerticalSpacing="8">
                                <Button Command="{Binding TrackSelectionCommand}"
                                        Content="Track Selection"
                                        automation:AutomationProperties.Name="Track selected control for memory diagnostics" />
                                <Button Command="{Binding RemoveCollectedCommand}"
                                        Content="Remove Collected"
                                        automation:AutomationProperties.Name="Remove collected tracked objects" />
                                <Button Command="{Binding ClearTrackedCommand}"
                                        Content="Clear"
                                        automation:AutomationProperties.Name="Clear tracked objects" />
                            </views:WrapPanel>
                        </StackPanel>

                        <Border Grid.Row="1"
                                MinHeight="0"
                                MinWidth="0"
                                Style="{StaticResource DevToolsDataPanelBorderStyle}">
                            <controls:TreeDataGrid x:Name="TrackedGrid"
                                                   HorizontalAlignment="Stretch"
                                                   VerticalAlignment="Stretch"
                                                   Source="{Binding TrackedSource}"
                                                   automation:AutomationProperties.Name="Tracked objects grid" />
                        </Border>
                    </Grid>
                </TabViewItem>
                <TabViewItem Header="Inspector">
                    <Grid MinHeight="0"
                          MinWidth="0"
                          Padding="0,8,0,0">
                        <views:MemoryObjectDetailsView x:Name="DetailsView"
                                                       HorizontalAlignment="Stretch"
                                                       VerticalAlignment="Stretch"
                                                       DataContext="{Binding Details}" />
                    </Grid>
                </TabViewItem>
            </TabView>
        </Grid>
    </Grid>
</UserControl>
