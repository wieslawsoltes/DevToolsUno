<UserControl
    x:Class="DevToolsUno.Diagnostics.Views.BindingsPageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:automation="using:Microsoft.UI.Xaml.Automation"
    xmlns:controls="using:Uno.Controls"
    xmlns:views="using:DevToolsUno.Diagnostics.Views"
    automation:AutomationProperties.Name="Bindings inspection page">
    <Grid x:Name="LayoutRoot"
          MinHeight="0"
          MinWidth="0"
          ColumnSpacing="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.15*" />
            <ColumnDefinition Width="1.85*" />
        </Grid.ColumnDefinitions>

        <Grid MinHeight="0"
              MinWidth="0"
              RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="8">
                <StackPanel Spacing="4">
                    <TextBlock Style="{StaticResource DevToolsPageTitleTextStyle}"
                               Text="Bindings" />
                    <TextBlock Style="{StaticResource DevToolsBodyTextStyle}"
                               Text="{Binding InspectionTargetSummary}"
                               TextWrapping="WrapWholeWords" />
                </StackPanel>
                <views:WrapPanel HorizontalSpacing="8"
                                 VerticalSpacing="8">
                    <Button Command="{Binding RefreshCommand}"
                            Content="Refresh"
                            automation:AutomationProperties.Name="Refresh bindings" />
                </views:WrapPanel>
            </StackPanel>

            <Grid Grid.Row="1"
                  ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox PlaceholderText="Filter bindings by property, path, source, or value"
                         Text="{Binding Filter.FilterString, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         automation:AutomationProperties.Name="Filter bindings" />
                <ComboBox Grid.Column="1"
                          Width="120"
                          ItemsSource="{Binding SortOptions}"
                          SelectedItem="{Binding SelectedSortOption, Mode=TwoWay}"
                          automation:AutomationProperties.Name="Sort bindings by" />
                <ToggleButton Grid.Column="2"
                              IsChecked="{Binding SortDescending, Mode=TwoWay}"
                              Content="Descending"
                              automation:AutomationProperties.Name="Toggle descending binding sort" />
            </Grid>

            <TextBlock Grid.Row="2"
                       Foreground="{ThemeResource DevToolsForegroundCaptionBrush}"
                       Text="{Binding BindingCountText}" />

            <Border Grid.Row="3"
                    MinHeight="0"
                    MinWidth="0"
                    Style="{StaticResource DevToolsDataPanelBorderStyle}">
                <controls:TreeDataGrid x:Name="BindingsGrid"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Stretch"
                                       Source="{Binding BindingSource}"
                                       automation:AutomationProperties.Name="Bindings grid" />
            </Border>
        </Grid>

        <Grid Grid.Column="1"
              MinHeight="0"
              MinWidth="0"
              RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="8">
                <StackPanel Spacing="4">
                    <TextBlock Style="{StaticResource DevToolsPageTitleTextStyle}"
                               Text="{Binding SelectedBindingName}" />
                    <TextBlock Style="{StaticResource DevToolsBodyTextStyle}"
                               Text="{Binding SelectedBindingSummary}"
                               TextWrapping="WrapWholeWords" />
                    <TextBlock Style="{StaticResource DevToolsMetaTextStyle}"
                               Text="{Binding SelectedBindingPath}"
                               TextWrapping="WrapWholeWords" />
                </StackPanel>
                <views:WrapPanel HorizontalSpacing="8"
                                 VerticalSpacing="8">
                    <Button Command="{Binding CopySelectedPathCommand}"
                            Content="Copy Path"
                            automation:AutomationProperties.Name="Copy selected binding path" />
                    <Button Command="{Binding CopySelectedValueCommand}"
                            Content="Copy Value"
                            automation:AutomationProperties.Name="Copy selected binding value" />
                </views:WrapPanel>
            </StackPanel>

            <TabView x:Name="ContentTabs"
                     Grid.Row="1"
                     MinHeight="0"
                     MinWidth="0"
                     Style="{StaticResource DevToolsEmbeddedTabViewStyle}">
                <TabViewItem Header="Facts">
                    <Grid MinHeight="0"
                          MinWidth="0"
                          Padding="0,8,0,0">
                        <Border MinHeight="0"
                                MinWidth="0"
                                Style="{StaticResource DevToolsDataPanelBorderStyle}">
                            <ListView x:Name="DetailList"
                                      ItemsSource="{Binding DetailItems}"
                                      SelectedItem="{Binding SelectedDetailItem, Mode=TwoWay}"
                                      Style="{StaticResource DevToolsFlatListViewStyle}"
                                      automation:AutomationProperties.Name="Binding facts">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,8" ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock FontWeight="SemiBold"
                                                       Foreground="{ThemeResource DevToolsForegroundBrush}"
                                                       Text="{Binding Name}" />
                                            <StackPanel Grid.Column="1"
                                                        Spacing="2">
                                                <TextBlock Foreground="{ThemeResource DevToolsForegroundMutedBrush}"
                                                           Text="{Binding Value}"
                                                           TextWrapping="WrapWholeWords" />
                                                <TextBlock FontSize="12"
                                                           Foreground="{ThemeResource DevToolsForegroundSubtleBrush}"
                                                           Text="{Binding Detail}"
                                                           TextWrapping="WrapWholeWords" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Border>
                    </Grid>
                </TabViewItem>
                <TabViewItem Header="Object Inspector">
                    <Grid MinHeight="0"
                          MinWidth="0"
                          Padding="0,8,0,0">
                        <views:BindingObjectDetailsView x:Name="DetailsView"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Stretch"
                                                        DataContext="{Binding Details}" />
                    </Grid>
                </TabViewItem>
            </TabView>
        </Grid>
    </Grid>
</UserControl>
