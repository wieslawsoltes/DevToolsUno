<UserControl
    x:Class="DevToolsUno.Diagnostics.Views.StyleValueDetailsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:automation="using:Microsoft.UI.Xaml.Automation"
    xmlns:controls="using:Avalonia.Controls"
    xmlns:views="using:DevToolsUno.Diagnostics.Views"
    automation:AutomationProperties.Name="Style details">
    <Grid x:Name="LayoutRoot"
          MinHeight="0"
          MinWidth="0"
          Padding="{ThemeResource DevToolsPagePadding}"
          RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="8">
            <StackPanel Spacing="4">
                <TextBlock Style="{StaticResource DevToolsPageTitleTextStyle}"
                           Text="{Binding Title}" />
                <TextBlock Style="{StaticResource DevToolsMetaTextStyle}"
                           Text="{Binding Subtitle}" />
                <TextBlock Style="{StaticResource DevToolsBodyTextStyle}"
                           Text="{Binding Summary}"
                           TextWrapping="WrapWholeWords" />
            </StackPanel>
            <views:WrapPanel HorizontalSpacing="8"
                             VerticalSpacing="8">
                <Button Command="{Binding CopySelectedPropertyValueCommand}"
                        Content="Copy Property Value"
                        automation:AutomationProperties.Name="Copy selected style property value" />
            </views:WrapPanel>
        </StackPanel>

        <TabView x:Name="InspectorTabs"
                 Grid.Row="1"
                 MinHeight="0"
                 MinWidth="0"
                 Style="{StaticResource DevToolsEmbeddedTabViewStyle}">
            <TabViewItem Header="Properties">
                <Grid MinHeight="0"
                      MinWidth="0"
                      Padding="0,8,0,0"
                      RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBox PlaceholderText="Filter style details properties"
                             Text="{Binding Filter.FilterString, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             automation:AutomationProperties.Name="Filter style details properties" />

                    <Border Grid.Row="1"
                            MinHeight="0"
                            MinWidth="0"
                            Style="{StaticResource DevToolsDataPanelBorderStyle}">
                        <controls:TreeDataGrid x:Name="PropertyGrid"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Stretch"
                                               Source="{Binding PropertySource}"
                                               automation:AutomationProperties.Name="Style details property grid" />
                    </Border>
                </Grid>
            </TabViewItem>
            <TabViewItem Header="Overview">
                <ScrollViewer MinHeight="0"
                              MinWidth="0"
                              Padding="0,8,0,0"
                              automation:AutomationProperties.Name="Style details metadata">
                    <StackPanel Spacing="10">
                        <Border Style="{StaticResource DevToolsInspectorCardBorderStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock Style="{StaticResource DevToolsSectionTitleTextStyle}" Text="Selected Property" />
                                <ContentControl Content="{Binding SelectedProperty}"
                                                ContentTemplate="{StaticResource SelectedPropertyEditorTemplate}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource DevToolsInspectorCardBorderStyle}">
                            <StackPanel Spacing="4">
                                <TextBlock Style="{StaticResource DevToolsSectionTitleTextStyle}"
                                           Text="Object" />
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Foreground="{ThemeResource DevToolsForegroundCaptionBrush}" Text="Value:" />
                                    <TextBlock Foreground="{ThemeResource DevToolsForegroundMutedBrush}" Text="{Binding ValueText}" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Foreground="{ThemeResource DevToolsForegroundCaptionBrush}" Text="Type:" />
                                    <TextBlock Foreground="{ThemeResource DevToolsForegroundMutedBrush}" Text="{Binding ValueType}" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Foreground="{ThemeResource DevToolsForegroundCaptionBrush}" Text="Kind:" />
                                    <TextBlock Foreground="{ThemeResource DevToolsForegroundMutedBrush}" Text="{Binding Kind}" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Foreground="{ThemeResource DevToolsForegroundCaptionBrush}" Text="Owner:" />
                                    <TextBlock Foreground="{ThemeResource DevToolsForegroundMutedBrush}" Text="{Binding Owner}" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Foreground="{ThemeResource DevToolsForegroundCaptionBrush}" Text="Path:" />
                                    <TextBlock Foreground="{ThemeResource DevToolsForegroundMutedBrush}" Text="{Binding Path}" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>
            <TabViewItem Header="Sources">
                <Grid MinHeight="0"
                      MinWidth="0"
                      Padding="0,8,0,0">
                    <Border MinHeight="0"
                            MinWidth="0"
                            Style="{StaticResource DevToolsDataPanelBorderStyle}">
                        <controls:TreeDataGrid Source="{Binding ValueSourceGrid}"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Stretch"
                                               automation:AutomationProperties.Name="Style property sources" />
                    </Border>
                </Grid>
            </TabViewItem>
        </TabView>
    </Grid>
</UserControl>
