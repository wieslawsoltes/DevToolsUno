<UserControl
    x:Class="DevToolsUno.Diagnostics.Views.EventsPageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:automation="using:Microsoft.UI.Xaml.Automation"
    xmlns:controls="using:Uno.Controls"
    xmlns:views="using:DevToolsUno.Diagnostics.Views"
    automation:AutomationProperties.Name="Events page">
    <UserControl.Resources>
        <DataTemplate x:Key="EventListenerCellTemplate">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <CheckBox IsThreeState="True"
                          VerticalAlignment="Center"
                          IsChecked="{Binding IsChecked, Mode=TwoWay}"
                          automation:AutomationProperties.Name="Toggle event listener" />
                <StackPanel Grid.Column="1"
                            Spacing="1">
                    <TextBlock Foreground="{ThemeResource DevToolsForegroundBrush}"
                               Text="{Binding Name}" />
                    <TextBlock FontSize="12"
                               Foreground="{ThemeResource DevToolsForegroundCaptionBrush}"
                               Text="{Binding Summary}" />
                </StackPanel>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>
    <Grid x:Name="LayoutRoot"
          Padding="{ThemeResource DevToolsPagePadding}"
          MinHeight="0"
          MinWidth="0"
          ColumnSpacing="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="ListenerColumn"
                              Width="340"
                              MinWidth="240" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition x:Name="ResultsColumn"
                              Width="*"
                              MinWidth="420" />
        </Grid.ColumnDefinitions>

        <Grid MinHeight="0"
              MinWidth="0"
              Margin="0,0,8,0"
              RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="4">
                <TextBlock Style="{StaticResource DevToolsPageTitleTextStyle}"
                           Text="{Binding SelectedListenerTitle}" />
                <TextBlock Style="{StaticResource DevToolsBodyTextStyle}"
                           Text="{Binding SelectedListenerSummary}"
                           TextWrapping="WrapWholeWords" />
            </StackPanel>

            <views:WrapPanel Grid.Row="1"
                             HorizontalSpacing="8"
                             VerticalSpacing="8">
                <Button Command="{Binding EnableDefaultsCommand}"
                        Content="Defaults"
                        automation:AutomationProperties.Name="Enable default event listeners" />
                <Button Command="{Binding EnableAllCommand}"
                        Content="Enable All"
                        automation:AutomationProperties.Name="Enable all event listeners" />
                <Button Command="{Binding DisableAllCommand}"
                        Content="Disable All"
                        automation:AutomationProperties.Name="Disable all event listeners" />
                <TextBlock VerticalAlignment="Center"
                           Foreground="{ThemeResource DevToolsForegroundCaptionBrush}"
                           Text="{Binding EnabledListenerCountText}" />
            </views:WrapPanel>

            <Border Grid.Row="2"
                    MinHeight="0"
                    MinWidth="0"
                    Style="{StaticResource DevToolsDataPanelBorderStyle}">
                <controls:TreeDataGrid x:Name="ListenersGrid"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Stretch"
                                       Source="{Binding ListenerTreeSource}"
                                       automation:AutomationProperties.Name="Event listeners tree" />
            </Border>
        </Grid>

        <Border x:Name="PaneSplitter"
                Grid.Column="1"
                Width="8"
                Background="Transparent"
                PointerCaptureLost="OnPaneSplitterPointerCaptureLost"
                PointerMoved="OnPaneSplitterPointerMoved"
                PointerPressed="OnPaneSplitterPointerPressed"
                PointerReleased="OnPaneSplitterPointerReleased"
                automation:AutomationProperties.Name="Resize events listeners and results panes" />

        <Grid x:Name="ResultsRoot"
              Grid.Column="2"
              MinHeight="0"
              MinWidth="0"
              Margin="8,0,0,0">
            <TabView x:Name="ResultsTabs"
                     MinHeight="0"
                     MinWidth="0"
                     Style="{StaticResource DevToolsEmbeddedTabViewStyle}">
                <TabViewItem Header="Log">
                    <Grid MinHeight="0"
                          MinWidth="0"
                          Padding="0,8,0,0"
                          RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Spacing="8">
                            <StackPanel Spacing="4">
                                <TextBlock Style="{StaticResource DevToolsPageTitleTextStyle}"
                                           Text="Raised events" />
                                <TextBlock Style="{StaticResource DevToolsBodyTextStyle}"
                                           Text="{Binding EventCountText}" />
                            </StackPanel>
                            <views:WrapPanel HorizontalSpacing="8"
                                             VerticalSpacing="8">
                                <Button Command="{Binding ToggleCaptureCommand}"
                                        Content="{Binding ToggleCaptureText}"
                                        automation:AutomationProperties.Name="Pause or resume event capture" />
                                <Button Command="{Binding ClearCommand}"
                                        Content="Clear"
                                        automation:AutomationProperties.Name="Clear raised event log" />
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="{ThemeResource DevToolsForegroundCaptionBrush}"
                                           Text="Capturing:" />
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="{ThemeResource DevToolsForegroundBrush}"
                                           Text="{Binding IsCapturing}" />
                            </views:WrapPanel>
                        </StackPanel>

                        <Border Grid.Row="1"
                                MinHeight="0"
                                MinWidth="0"
                                Style="{StaticResource DevToolsDataPanelBorderStyle}">
                            <controls:TreeDataGrid x:Name="EventLogGrid"
                                                   HorizontalAlignment="Stretch"
                                                   VerticalAlignment="Stretch"
                                                   Source="{Binding LogSource}"
                                                   automation:AutomationProperties.Name="Raised events log" />
                        </Border>
                    </Grid>
                </TabViewItem>
                <TabViewItem Header="Route">
                    <Grid MinHeight="0"
                          MinWidth="0"
                          Padding="0,8,0,0"
                          RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Spacing="8">
                            <StackPanel Spacing="4">
                                <TextBlock Style="{StaticResource DevToolsPageTitleTextStyle}"
                                           Text="{Binding SelectedEventTitle}" />
                                <TextBlock Style="{StaticResource DevToolsBodyTextStyle}"
                                           Text="{Binding SelectedEventSummary}"
                                           TextWrapping="WrapWholeWords" />
                                <TextBlock Style="{StaticResource DevToolsMetaTextStyle}"
                                           Text="{Binding SelectedEventSourceSelector}"
                                           TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <views:WrapPanel HorizontalSpacing="8"
                                             VerticalSpacing="8">
                                <Button Command="{Binding InspectSelectedSourceCommand}"
                                        Content="Inspect Source"
                                        automation:AutomationProperties.Name="Inspect selected event source in tree" />
                                <Button Command="{Binding InspectSelectedRouteElementCommand}"
                                        Content="Inspect Route Element"
                                        automation:AutomationProperties.Name="Inspect selected route element in tree" />
                            </views:WrapPanel>
                        </StackPanel>

                        <Border Grid.Row="1"
                                MinHeight="0"
                                MinWidth="0"
                                Style="{StaticResource DevToolsDataPanelBorderStyle}">
                            <controls:TreeDataGrid x:Name="RoutesGrid"
                                                   HorizontalAlignment="Stretch"
                                                   VerticalAlignment="Stretch"
                                                   Source="{Binding RouteSource}"
                                                   automation:AutomationProperties.Name="Observed event route" />
                        </Border>
                    </Grid>
                </TabViewItem>
            </TabView>
        </Grid>
    </Grid>
</UserControl>
